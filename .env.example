# ============================================================
# RAG Enterprise Pro — Environment Variables
# ============================================================
# Copy file này thành .env và điền các giá trị phù hợp:
#   cp .env.example .env
# ============================================================

# ---------- LLM API Keys ----------
# Google Gemini API key (bắt buộc)
GEMINI_API_KEY=your-gemini-api-key-here
# GOOGLE_API_KEY (alias, ưu tiên GEMINI_API_KEY nếu set cả hai)
# GOOGLE_API_KEY=your-google-api-key-here

# ---------- Vector Database (Qdrant) ----------
# Qdrant URL: bỏ trống để dùng local file-based
QDRANT_URL=
# Qdrant API key (nếu dùng cloud)
QDRANT_API_KEY=
# Local storage path cho Qdrant (mặc định: ./qdrant_data)
QDRANT_PATH=./qdrant_data
# Tên collection trong Qdrant (mặc định: enterprise_rag)
QDRANT_COLLECTION=enterprise_rag
# Kích thước dense vector (mặc định: 1024 cho bge-m3)
DENSE_VECTOR_SIZE=1024
# Kích thước sparse vector Qdrant (mặc định: 1048576)
SPARSE_VECTOR_DIM=1048576
# Tên sparse vector trong Qdrant (mặc định: bm25)
QDRANT_SPARSE_VECTOR_NAME=bm25

# ---------- Storage ----------
# Thư mục dữ liệu đầu vào (mặc định: data)
DATA_DIR=data
# Thư mục lưu docstore (mặc định: ./docstore)
DOCSTORE_DIR=./docstore

# ---------- Feature Flags ----------
# Bật/tắt sparse BM25 search (mặc định: true)
USE_SPARSE_BM25=true
# Bật/tắt retrieval cache (mặc định: true)
ENABLE_RETRIEVAL_CACHE=true
# Bật/tắt verbose cho AutoMergingRetriever (mặc định: false)
AUTO_MERGE_VERBOSE=false

# ---------- Retrieval Tuning ----------
# Số lượng kết quả từ vector search (mặc định: 20)
RETRIEVAL_TOP_K=20
# Số lượng kết quả từ sparse search (mặc định: 20, fallback về RETRIEVAL_TOP_K)
SPARSE_TOP_K=20
# Số lượng kết quả cuối cùng sau rerank (mặc định: 8)
FINAL_TOP_N=8
# Kích thước pool cho reranker (mặc định: 24)
RERANK_POOL_SIZE=24
# Số lượng query rewrite tối đa (mặc định: 3)
MAX_QUERY_REWRITES=3
# Kích thước cache retrieval (mặc định: 64 entries)
RETRIEVAL_CACHE_SIZE=64
# Batch size cho sparse vector upsert (mặc định: 128)
SPARSE_UPSERT_BATCH=128

# ---------- Evidence Gating ----------
# Điểm số tối thiểu để coi là bằng chứng mạnh (mặc định: 0.55)
EVIDENCE_MIN_SCORE=0.55
# Số lượng nodes tối thiểu đạt ngưỡng (mặc định: 1)
EVIDENCE_MIN_COUNT=1
# Ngưỡng chênh lệch để phát hiện mâu thuẫn (mặc định: 0.05)
EVIDENCE_CONFLICT_MARGIN=0.05

# ---------- Ingestion ----------
# Số lần retry tối đa cho mỗi file (mặc định: 2)
INGEST_MAX_RETRIES=2

# ---------- Upload ----------
# Kích thước file tối đa (MB, mặc định: 100)
MAX_UPLOAD_SIZE_MB=100

# ---------- Authentication ----------
# Danh sách API keys (phân cách bằng dấu phẩy). Để trống để tắt authentication.
# Khi bật, tất cả request (trừ /health) cần header X-API-Key.
API_KEYS=
# Tên header chứa API key (mặc định: X-API-Key)
# API_KEY_HEADER=X-API-Key
# File JSON lưu dynamic API keys (tạo/thu hồi qua admin UI, mặc định: api_keys.json)
# API_KEYS_FILE=api_keys.json

# ---------- Rate Limiting ----------
# Số request tối đa mỗi phút cho chat endpoint (mặc định: 20)
RATE_LIMIT_CHAT=20/minute
# Số request tối đa mỗi phút cho upload (mặc định: 10)
RATE_LIMIT_UPLOAD=10/minute
# Số request tối đa mỗi phút cho index (mặc định: 5)
RATE_LIMIT_HEAVY=5/minute
# Số request tối đa mỗi phút cho endpoints nhẹ (files, status) (mặc định: 60)
RATE_LIMIT_LIGHT=60/minute
# Số request tối đa mỗi phút cho endpoints trung bình (delete) (mặc định: 30)
RATE_LIMIT_MEDIUM=30/minute

# ---------- Server ----------
# CORS origins (phân cách bằng dấu phẩy), mặc định localhost ports
CORS_ORIGINS=http://localhost:8501,http://localhost:5500,http://localhost:3000,http://localhost:8000

# ---------- Logging ----------
# Log level: DEBUG, INFO, WARNING, ERROR (mặc định: INFO)
LOG_LEVEL=INFO

# ---------- Evaluation ----------
# Model Gemini dùng làm judge cho RAGAS (mặc định: gemini-flash-latest)
# RAGAS_JUDGE_MODEL=gemini-flash-latest
# Embedding model cho RAGAS (mặc định: models/embedding-001)
# RAGAS_EMBEDDING_MODEL=models/embedding-001
